{
  "name": "memeloop",
  "version": "0.0.0",
  "description": "MemeLoop core runtime: agent framework, storage, sync engine, tools, IM adapter.",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "peerDependencies": {
    "ai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --sourcemap --external ai",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@inrupt/solid-client": "^2.0.0",
    "@memeloop/protocol": "workspace:*",
    "json5": "^2.2.3",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.24.0",
    "better-sqlite3": "^12.4.5",
    "bonjour-service": "^1.2.0",
    "faye-websocket": "^0.11.4"
  },
  "devDependencies": {
    "ai": "^4.0.0",
    "@types/better-sqlite3": "^7.6.9",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0"
  }
}

