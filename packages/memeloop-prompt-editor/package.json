{
  "name": "@memeloop/prompt-editor",
  "version": "0.0.0",
  "description": "Platform-agnostic prompt editor (RJSF schema + Web/RN widgets).",
  "license": "MIT",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./web": {
      "types": "./dist/web/index.d.ts",
      "import": "./dist/web/index.mjs",
      "require": "./dist/web/index.js"
    },
    "./native": {
      "types": "./dist/native/index.d.ts",
      "import": "./dist/native/index.mjs",
      "require": "./dist/native/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts src/web/index.ts src/native/index.ts --format cjs,esm --dts --sourcemap",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "@rjsf/core": ">=5.0.0",
    "@rjsf/utils": ">=5.0.0",
    "@rjsf/validator-ajv8": ">=5.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@rjsf/mui": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rjsf/core": "^5.0.0",
    "@rjsf/mui": "^5.0.0",
    "@rjsf/utils": "^5.0.0",
    "@rjsf/validator-ajv8": "^5.0.0",
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0"
  }
}
