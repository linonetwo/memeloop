{
  "name": "memeloop-monorepo",
  "private": true,
  "version": "0.0.0",
  "pnpm": {
    "overrides": {
      "better-sqlite3": "^12.4.5"
    }
  },
  "description": "MemeLoop open-source monorepo (protocol, core runtime, prompt-editor, node).",
  "license": "MIT",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "eslint \"packages/*/src/**/*.{ts,tsx}\"",
    "test": "pnpm -r run test",
    "test:unit": "pnpm -r run test:unit",
    "test:ci": "pnpm test && pnpm --filter memeloop-node run test:e2e",
    "test:coverage": "pnpm -r run test:coverage",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-config-tidgi": "^2.2.0",
    "eslint-plugin-import": "^2.29.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
